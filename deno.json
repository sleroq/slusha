{
    "compilerOptions": {
        "strict": true
    },
    "lint": {
        "include": [
            "*.ts",
            "lib/"
        ],
        "rules": {
            "tags": [
                "recommended"
            ]
        }
    },
    "fmt": {
        "include": [
            "*.ts",
            "lib/"
        ],
        "useTabs": false,
        "lineWidth": 80,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": true,
        "proseWrap": "preserve"
    },
    "nodeModulesDir": "auto",
    "imports": {
        "@google/genai": "npm:@google/genai@^2.10.0",
        "@opentelemetry/auto-instrumentations-node": "npm:@opentelemetry/auto-instrumentations-node@^0.78.0",
        "@opentelemetry/sdk-node": "npm:@opentelemetry/sdk-node@^0.220.0",
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/encoding": "jsr:@std/encoding@^1.0.11",
        "@std/fs": "jsr:@std/fs@^1.0.24",
        "ai": "npm:ai@^7.0.16",
        "@ai-sdk/google": "npm:@ai-sdk/google@^4.0.8",
        "@ai-sdk/openai-compatible": "npm:@ai-sdk/openai-compatible@^3.0.5",
        "@libsql/client": "npm:@libsql/client@^0.17.4",
        "@deno-library/logger": "jsr:@deno-library/logger@^1.2.0",
        "drizzle-kit": "npm:drizzle-kit@^0.31.10",
        "drizzle-orm": "npm:drizzle-orm@^0.45.2",
        "grammy": "npm:grammy@^1.44.0",
        "@grammyjs/runner": "npm:@grammyjs/runner@^2.0.3",
        "grammy_types": "npm:@grammyjs/types@^3.28.0",
        "isomorphic-dompurify": "npm:isomorphic-dompurify@^3.18.0",
        "ky": "npm:ky@^2.0.2",
        "grammy_ratelimiter": "npm:@grammyjs/ratelimiter@^1.2.1",
        "@grammyjs/i18n": "npm:@grammyjs/i18n@^1.1.2",
        "langfuse-vercel": "npm:langfuse-vercel@^3.38.20",
        "prom-client": "npm:prom-client@15.1.3",
        "prom-client/": "npm:prom-client@15.1.3/",
        "remark-html": "npm:remark-html@^16.0.1",
        "remark-parse": "npm:remark-parse@^11.0.0",
        "unified": "npm:unified@^11.0.5",
        "zod": "npm:zod@^4.4.3"
    },
    "allowScripts": [
        "npm:@google/genai@2.10.0",
        "npm:esbuild@0.18.20",
        "npm:esbuild@0.25.12",
        "npm:esbuild@0.28.1",
        "npm:fsevents@2.3.3",
        "npm:protobufjs@7.6.5"
    ]
}
