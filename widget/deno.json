{
  "nodeModulesDir": "auto",
  "imports": {
    "@tma.js/sdk": "npm:@tma.js/sdk@^3.2.2",
    "@tma.js/sdk-svelte": "npm:@tma.js/sdk-svelte@^1.0.21",
    "svelte": "npm:svelte@^5.56.3",
    "@internationalized/date": "npm:@internationalized/date@^3.12.2",
    "@lucide/svelte": "npm:@lucide/svelte@^1.18.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.1.2",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.1",
    "@eslint/js": "npm:@eslint/js@^10.0.1",
    "bits-ui": "npm:bits-ui@^2.18.1",
    "clsx": "npm:clsx@^2.1.1",
    "eslint": "npm:eslint@^10.5.0",
    "eslint-plugin-svelte": "npm:eslint-plugin-svelte@^3.19.0",
    "svelte-eslint-parser": "npm:svelte-eslint-parser@^1.8.0",
    "tailwind-merge": "npm:tailwind-merge@^3.6.0",
    "tailwind-variants": "npm:tailwind-variants@^3.2.2",
    "tailwindcss": "npm:tailwindcss@^4.3.1",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "typescript": "npm:typescript@^6.0.3",
    "typescript-eslint": "npm:typescript-eslint@^8.61.0",
    "vite": "npm:vite@^8.0.16"
  },
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports", "no-window"]
    }
  },
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "check": "deno check src/main.ts && deno run -A npm:svelte-check --tsconfig ./tsconfig.json",
    "lint:deno": "deno lint",
    "lint:eslint": "deno run -A npm:eslint \"src/**/*.{ts,svelte}\"",
    "lint": "deno task lint:deno && deno task lint:eslint"
  }
}
