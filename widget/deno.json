{
  "nodeModulesDir": "auto",
  "imports": {
    "@tma.js/sdk": "npm:@tma.js/sdk@^3.1.7",
    "@tma.js/sdk-svelte": "npm:@tma.js/sdk-svelte@^1.0.16",
    "svelte": "npm:svelte@^5.38.10",
    "@internationalized/date": "npm:@internationalized/date@^3.12.0",
    "@lucide/svelte": "npm:@lucide/svelte@^0.561.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^4.0.4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "@eslint/js": "npm:@eslint/js@^9.35.0",
    "bits-ui": "npm:bits-ui@^2.16.3",
    "clsx": "npm:clsx@^2.1.1",
    "eslint": "npm:eslint@^9.35.0",
    "eslint-plugin-svelte": "npm:eslint-plugin-svelte@^3.12.4",
    "svelte-eslint-parser": "npm:svelte-eslint-parser@^1.3.1",
    "tailwind-merge": "npm:tailwind-merge@^3.5.0",
    "tailwind-variants": "npm:tailwind-variants@^3.2.2",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "typescript": "npm:typescript@^5.9.2",
    "typescript-eslint": "npm:typescript-eslint@^8.42.0",
    "vite": "npm:vite@^5.4.19"
  },
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports", "no-window"]
    }
  },
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "check": "deno check src/main.ts && deno run -A npm:svelte-check --tsconfig ./tsconfig.json",
    "lint:deno": "deno lint",
    "lint:eslint": "deno run -A npm:eslint \"src/**/*.{ts,svelte}\"",
    "lint": "deno task lint:deno && deno task lint:eslint"
  }
}
